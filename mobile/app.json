{
  "expo": {
    "name": "JungfrauPass",
    "slug": "jungfraupass",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1A5276"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.jungfraupass.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Used to scan partner QR codes for payments and benefit redemptions.",
        "NSLocationWhenInUseUsageDescription": "Used to check in at landmarks and earn discovery points."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1A5276"
      },
      "package": "com.jungfraupass.app",
      "permissions": ["CAMERA", "ACCESS_FINE_LOCATION"]
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-camera",
      ["expo-location", { "locationAlwaysAndWhenInUsePermission": "Allow JungfrauPass to use your location." }]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "scheme": "jungfraupass"
  }
}
