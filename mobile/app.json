{
  "expo": {
    "name": "JungfrauPass",
    "slug": "jungfraupass",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#1A5276"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.jungfraupass.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Used to scan partner QR codes for payments and benefit redemptions.",
        "NSPhotoLibraryUsageDescription": "Used to pick a QR code image from your photo library.",
        "NSLocationWhenInUseUsageDescription": "Used to check in at landmarks and earn discovery points."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#1A5276"
      },
      "package": "com.jungfraupass.app",
      "permissions": [
        "CAMERA",
        "READ_MEDIA_IMAGES",
        "READ_EXTERNAL_STORAGE",
        "ACCESS_FINE_LOCATION"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-camera",
      "expo-image-picker",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow JungfrauPass to use your location."
        }
      ],
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "scheme": "jungfraupass"
  }
}
